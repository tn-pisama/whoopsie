# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Generate a fresh ID at https://whoopsie.dev/install
# (or just make one up: ws_<16 random alphanumeric>)
WHOOPSIE_PROJECT_ID=ws_replace_me

# Exposed to the client so the dashboard URL can render in the UI.
# Same value as WHOOPSIE_PROJECT_ID.
NEXT_PUBLIC_WHOOPSIE_PROJECT_ID=ws_replace_me
