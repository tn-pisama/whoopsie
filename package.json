{
  "name": "whoopsie",
  "private": true,
  "version": "0.0.0",
  "description": "See your AI app's failures live.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @whoopsie/web dev",
    "start": "pnpm --filter @whoopsie/web start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @whoopsie/detectors test && pnpm --filter @whoopsie/sdk test && pnpm --filter @whoopsie/cli test && pnpm --filter @whoopsie/web test",
    "smoke": "./scripts/smoke.sh",
    "synth": "pnpm --filter @whoopsie/synth start",
    "synth:once": "pnpm --filter @whoopsie/synth once",
    "contacts:list": "pnpm --filter @whoopsie/web exec tsx scripts/contacts.ts",
    "tos:list": "pnpm --filter @whoopsie/web exec tsx scripts/tos.ts",
    "release": "pnpm -r --filter ./packages/* publish --access public --no-git-checks"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
