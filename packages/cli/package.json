{
  "name": "@whoopsie/cli",
  "version": "0.0.1",
  "description": "CLI for whoopsie.dev. Run `npx @whoopsie/cli init` in your Next.js + AI SDK project.",
  "type": "module",
  "bin": {
    "whoopsie": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'test/**/*.test.ts'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "kleur": "^4.1.5",
    "nanoid": "^5.0.0",
    "open": "^10.0.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tn-pisama/whoopsie",
    "directory": "packages/cli"
  },
  "homepage": "https://whoopsie.dev",
  "bugs": {
    "url": "https://github.com/tn-pisama/whoopsie/issues"
  }
}
