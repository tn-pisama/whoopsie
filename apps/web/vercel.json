{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && corepack enable && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter '@whoopsie/web...' build",
  "outputDirectory": ".next",
  "crons": [
    { "path": "/api/internal/cleanup", "schedule": "0 5 * * *" },
    { "path": "/api/internal/platform-health", "schedule": "0 14 * * *" }
  ]
}
